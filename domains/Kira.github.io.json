{
  "!! IMPORTANT !!": "Rename this file to 'yourname.is-a.dev.json' or 'yourname.is-a-fullstack.dev.json' based on domain choice",
  
  "===== FOR .is-a.dev DOMAIN =====": "Use this format for is-a.dev",
  "owner": {
    "username": "your-github-username"
  },
  "records": {
    "CNAME": "Kirafx.github.io"
  },

  "===== FOR .is-a-fullstack.dev DOMAIN =====": "Use this format for developer domains",
  "domain": "is-a-fullstack.dev",
  "subdomain": "github.io",
  "owner": {
    "email": "your@email.com",
    "repo": "https://github.com/yourusername/your-repo"
  },
  "records": {
    "CNAME": "your-github-username.github.io"
  },
  "proxied": false,

  "===== FOR .thedev.me DOMAIN =====": "Use this format for thedev.me",
  "email_or_discord": "user@example.com",
  "github_username": "yourusername",
  "description": "My personal developer website",

  "===== SUPPORTED RECORD TYPES =====": "Choose ONE record type based on your hosting",
  "A_RECORD_EXAMPLE": {
    "A": ["192.0.2.1"]
  },
  "AAAA_RECORD_EXAMPLE": {
    "AAAA": ["2001:0db8:85a3::8a2e:0370:7334"]
  },
  "CNAME_RECORD_EXAMPLE": {
    "CNAME": "yourusername.github.io"
  },
  "MX_RECORD_EXAMPLE": {
    "MX": [
      {
        "priority": 10,
        "value": "mx.example.com"
      }
    ]
  },
  "TXT_RECORD_EXAMPLE": {
    "TXT": ["verification=abc123"]
  },
  "URL_REDIRECT_EXAMPLE": {
    "URL": "https://your-actual-site.com"
  },

  "===== HOW TO SUBMIT =====": {
    "step1": "Fork the repository (github.com/is-a-dev/register for .is-a.dev)",
    "step2": "Create file in /domains folder with name: yourname.domain.json",
    "step3": "Replace 'your-github-username' with your actual GitHub username",
    "step4": "Keep ONLY one record type (delete the examples you don't need)",
    "step5": "Commit and create a Pull Request",
    "step6": "Wait for review and merge (24-72 hours)"
  },

